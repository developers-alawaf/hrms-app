MONGODB_URI=
JWT_SECRET=
PORT=5000
APP_TIMEZONE=Asia/Dhaka
APP_NAME=HRMS

# Frontend URL (required for invitation links, password reset links)
# Local: http://localhost:5173 | Production: https://hrms.kloud.com.bd
FRONTEND_URL=http://localhost:5173

# Email (for leave/remote notifications, password reset, invitations)
# Zoho region matters: use smtppro.zoho.in (India/Asia), smtppro.zoho.eu (Europe), or smtppro.zoho.com (US)
# If 535 auth fails with smtppro.zoho.com, try smtppro.zoho.in (India/Asia region)
# Gmail: smtp.gmail.com, port 587, MUST use App Password (myaccount.google.com/apppasswords)
MAIL_HOST=smtppro.zoho.in
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=HRMS

# Optional: ZKTeco device (leave empty to run without device sync)
# ZKTECO_DEVICE_IP=
# ZKTECO_DEVICE_PORT=4370
# ZKTECO_INPORT=5200