MONGODB_URI=
JWT_SECRET=
PORT=5000
APP_TIMEZONE=Asia/Dhaka
APP_NAME=HRMS

# Frontend URL (required for invitation links, password reset links)
# Local: http://localhost:5173 | Production: https://hrms.kloud.com.bd
FRONTEND_URL=http://localhost:5173

# Email (for leave/remote notifications, password reset, invitations)
# IMPORTANT: No spaces around = (e.g. MAIL_PASSWORD=yourpass not MAIL_PASSWORD= yourpass)
# 535 Authentication Failed? Zoho requires App Password (NOT regular password):
#   1. Go to https://accounts.zoho.com/home#security/app_password
#   2. Generate new App Password
#   3. Use that as MAIL_PASSWORD. Run: npm run test:email
# Zoho hosts: smtppro.zoho.in (India/Asia), smtppro.zoho.eu (Europe), smtppro.zoho.com (US)
# If 535 with .com, try .in. If 465 fails, try MAIL_PORT=587
MAIL_HOST=smtppro.zoho.in
MAIL_PORT=465
MAIL_USERNAME=tanzir.razzaque@alawaf.com.bd
MAIL_PASSWORD=Imtbgitw95
MAIL_FROM_ADDRESS=tanzir.razzaque@alawaf.com.bd
MAIL_FROM_NAME=HRMS
# Optional: set to true to verify SMTP on server start
# MAIL_VERIFY_ON_START=true

# Optional: ZKTeco device (leave empty to run without device sync)
# ZKTECO_DEVICE_IP=
# ZKTECO_DEVICE_PORT=4370
# ZKTECO_INPORT=5200